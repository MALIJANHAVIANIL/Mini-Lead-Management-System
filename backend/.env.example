# Lead Management System Configuration

# Server Port
PORT=5000

# JWT Authentication Secret Key
JWT_SECRET=your_jwt_secret_key_here

# Database Configuration
# Leave DATABASE_URL empty to use SQLite (zero-config database file).
# To use PostgreSQL, provide a standard connection string:
# DATABASE_URL=postgresql://username:password@localhost:5432/lead_db
DATABASE_URL=

# SQLite database path (used if DATABASE_URL is not set)
DB_PATH=./database.db
